---
import Base from './Base.astro';
import SidebarLeft from '../components/nav/SidebarLeft.astro';
import OutlineRight from '../components/content/OutlineRight.astro';
import Breadcrumb from '../components/nav/Breadcrumb.astro';
import GiscusComments from '../components/content/GiscusComments.astro';

interface Props {
  title: string;
  description?: string;
  module: number;
  seance: number;
  duree: string;
  niveau: string;
  date: Date;
  tpAssocie?: { label: string; url: string; };
  headings: any[];
}

const { title, description, module, seance, duree, niveau, date, tpAssocie, headings } = Astro.props;

const dateStr = new Intl.DateTimeFormat('fr-FR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);
---

<Base title={title} description={description} hideNavbar={true}>
  <nav class="flex flex-col sm:flex-row sm:items-center justify-between px-6 py-0 min-h-[60px] border-b border-[var(--glass-border)] bg-[rgba(8,11,18,0.75)] sticky top-0 z-50 backdrop-blur-xl">
    <div class="flex items-center gap-4 py-2 sm:py-0">
      <a href="/" class="font-syne font-extrabold text-[15px] bg-clip-text text-transparent bg-gradient-to-r from-[var(--electric)] to-[var(--violet)] no-underline">GL·Cloud</a>
      <div class="flex items-center text-[11px] text-[var(--muted)]">
        <Breadcrumb context="cours" module={module} seance={seance} title={title} />
      </div>
    </div>
    <div class="text-[10px] text-[var(--muted)] hidden sm:block">Modifié le {dateStr}</div>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-[240px_1fr_220px] min-h-[calc(100vh-60px)] relative z-10 w-full max-w-[1264px] mx-auto">
    <aside class="hidden lg:block border-r border-[var(--glass-border)] py-6 sticky top-[60px] h-[calc(100vh-60px)] overflow-y-auto">
      <SidebarLeft activeModule={module} activeSeance={seance} />
    </aside>

    <main class="w-full px-6 lg:px-13 py-10 max-w-[720px] mx-auto">
      <div class="inline-flex items-center gap-2 text-[9px] tracking-[0.14em] text-[var(--electric)] px-3 py-1.5 rounded-md bg-[rgba(110,231,247,0.08)] border border-[rgba(110,231,247,0.2)] mb-5">
        MODULE {module.toString().padStart(2, '0')} · SÉANCE {seance} · <span class="uppercase">{niveau}</span>
      </div>
      <h1 class="font-syne font-extrabold text-[38px] leading-[1.05] tracking-[-0.03em] mb-2 text-[var(--text)]">
        <span class="bg-gradient-to-r from-[var(--text)] from-40% to-[var(--electric)] bg-clip-text text-transparent">{title}</span>
      </h1>
      
      <div class="flex flex-wrap gap-0 mb-9 mt-5 bg-[var(--glass)] border border-[var(--glass-border)] rounded-xl overflow-hidden shadow-sm">
        <div class="flex-1 min-w-[100px] p-3 px-4 border-r border-[var(--glass-border)] last:border-r-0">
          <div class="text-[9px] tracking-[0.1em] text-[var(--muted)] mb-1">AUTEUR</div>
          <div class="text-[13px] text-[var(--text)] font-medium">Prof. Alami</div>
        </div>
        <div class="flex-1 min-w-[100px] p-3 px-4 border-r border-[var(--glass-border)] last:border-r-0">
          <div class="text-[9px] tracking-[0.1em] text-[var(--muted)] mb-1">DURÉE</div>
          <div class="text-[13px] text-[var(--text)] font-medium">{duree}</div>
        </div>
        <div class="flex-1 min-w-[100px] p-3 px-4 border-r border-[var(--glass-border)] last:border-r-0">
          <div class="text-[9px] tracking-[0.1em] text-[var(--muted)] mb-1">NIVEAU</div>
          <div class="text-[13px] text-[var(--text)] font-medium capitalize">{niveau}</div>
        </div>
        <div class="flex-1 min-w-[100px] p-3 px-4 border-r border-[var(--glass-border)] last:border-r-0 hidden sm:block">
          <div class="text-[9px] tracking-[0.1em] text-[var(--muted)] mb-1">DATE</div>
          <div class="text-[13px] text-[var(--text)] font-medium">{dateStr}</div>
        </div>
      </div>

      <div class="prose">
        <slot />
      </div>

      <GiscusComments />
    </main>

    <aside class="hidden lg:block border-l border-[var(--glass-border)] py-6 px-5 sticky top-[60px] h-[calc(100vh-60px)] overflow-y-auto">
      <OutlineRight headings={headings} />

      {tpAssocie && (
        <div class="mt-5 pt-5 border-t border-[var(--glass-border)]">
          <div class="bg-[rgba(110,231,247,0.04)] border border-[rgba(110,231,247,0.15)] rounded-xl p-4 mt-1">
            <div class="text-[9px] tracking-[0.12em] text-[var(--electric)] mb-2">TP ASSOCIÉ</div>
            <div class="text-[12px] text-[var(--text)] leading-[1.4] mb-3 font-medium">{tpAssocie.label}</div>
            <a href={tpAssocie.url} class="text-[10px] text-[var(--electric)] no-underline flex items-center gap-1 transition-all duration-150 hover:gap-2">Accéder au TP →</a>
          </div>
        </div>
      )}
    </aside>
  </div>
</Base>
