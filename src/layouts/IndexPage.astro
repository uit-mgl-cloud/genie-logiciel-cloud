---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
  headerLabel: string;
  headerCount?: string;
}

const { title, description, headerLabel, headerCount } = Astro.props;
---

<Base title={title} description={description}>
  <div class="px-6 md:px-12 lg:px-20 xl:px-32 py-8 border-b border-[var(--border)]">
    <h1 class="font-serif text-[36px] font-light leading-none tracking-tight text-[var(--text)] mb-2" set:html={title} />
    {description && <p class="text-[12px] text-[var(--muted)] max-w-2xl leading-relaxed mt-4">{description}</p>}
  </div>

  <div class="flex items-baseline justify-between px-6 md:px-12 lg:px-20 xl:px-32 py-8 border-b border-[var(--border)]">
    <span class="text-[10px] tracking-[0.12em] text-[var(--muted)] flex items-center gap-2 before:content-[''] before:inline-block before:w-3.5 before:h-[1px] before:bg-[var(--muted)]">
      {headerLabel.toUpperCase()}
    </span>
    {headerCount && <span class="text-[11px] text-[var(--hint)]">{headerCount}</span>}
  </div>

  <div class="w-full">
    <slot />
  </div>
</Base>
