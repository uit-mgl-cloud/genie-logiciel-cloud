---
import '../styles/global.css';
import '../styles/prose.css';
import '../styles/syntax.css';
import Navbar from '../components/nav/Navbar.astro';

interface Props {
  title: string;
  description?: string;
  hideNavbar?: boolean;
}

const { title, description = "Plateforme collaborative M2 GL Cloud", hideNavbar = false } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | GL·Cloud</title>
  </head>
  <body class="bg-[var(--bg)] text-[var(--text)] font-mono text-[13px] leading-relaxed flex flex-col min-h-screen">
    {!hideNavbar && <Navbar />}
    <main class="flex-grow">
      <slot />
    </main>
    <footer class="px-6 md:px-12 lg:px-20 xl:px-32 py-7 border-t border-[var(--border)] flex flex-col md:flex-row md:items-center justify-between gap-4 md:gap-0 mt-auto">
      <div class="text-[11px] text-[var(--hint)] text-center md:text-left">
        Génie Logiciel pour le Cloud · M2 Informatique · <span class="text-[var(--accent)]">Open Source</span> · GitHub
      </div>
      <div class="flex gap-5 justify-center">
        <a class="text-[11px] text-[var(--hint)] no-underline hover:text-[var(--muted)]" href="#">GitHub →</a>
        <a class="text-[11px] text-[var(--hint)] no-underline hover:text-[var(--muted)]" href="/contribuer">Guide contribution →</a>
        <a class="text-[11px] text-[var(--hint)] no-underline hover:text-[var(--muted)]" href="#">Discussions →</a>
      </div>
    </footer>
  </body>
</html>
