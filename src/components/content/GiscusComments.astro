---
---
<div class="mt-13 pt-8 border-t border-[var(--border)]">
  <div class="text-[10px] tracking-[0.1em] text-[var(--hint)] mb-5 flex items-center gap-2 before:content-[''] before:inline-block before:w-3.5 before:h-[1px] before:bg-[var(--hint)] uppercase">
    DISCUSSIONS · QUESTIONS
  </div>
  <div class="giscus">
    <div class="bg-[var(--bg-2)] border border-[var(--border)] rounded text-center p-7">
      <p class="text-[12px] text-[var(--hint)]"><span class="text-[var(--accent-2)]">giscus</span> — commentaires via GitHub Discussions<br>Connectez-vous avec votre compte GitHub pour poser une question.</p>
    </div>
  </div>
</div>

<script src="https://giscus.app/client.js"
        data-repo="[ENTER_GITHUB_ORG]/gl-cloud-computing"
        data-repo-id="[ENTER_REPO_ID]"
        data-category="Q&A"
        data-category-id="[ENTER_CATEGORY_ID]"
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="top"
        data-theme="preferred_color_scheme"
        data-lang="fr"
        crossorigin="anonymous"
        async>
</script>
