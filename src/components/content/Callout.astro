---
interface Props {
  type: 'note' | 'warning' | 'tip';
  title?: string;
}
const { type, title } = Astro.props;

const variants = {
  note: 'border-[var(--accent)] bg-[rgba(200,240,128,0.04)] text-[var(--accent)]',
  warning: 'border-amber-500 bg-amber-500/5 text-amber-500',
  tip: 'border-[var(--accent-2)] bg-[rgba(128,212,240,0.04)] text-[var(--accent-2)]'
};
const label = title || type.toUpperCase();
---
<div class={`border-l-2 py-3.5 px-4.5 my-5 rounded-r-sm ${variants[type]}`}>
  <div class="text-[9px] tracking-[0.1em] mb-1.5 uppercase font-medium">{label}</div>
  <div class="text-[12px] text-[var(--muted)] leading-relaxed m-0 [&>p]:!m-0">
    <slot />
  </div>
</div>
