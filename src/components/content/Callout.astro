---
interface Props {
  type: 'note' | 'warning' | 'tip';
  title?: string;
}
const { type, title } = Astro.props;

const variants = {
  note: 'border-[var(--primary-container)] text-[var(--primary-container)]',
  warning: 'border-[#FB7185] text-[#FB7185]',
  tip: 'border-[var(--secondary)] text-[var(--secondary)]'
};
const label = title || type.toUpperCase();
---
<div class={`border border-[var(--ghost-border)] border-l-4 py-5 px-6 my-8 bg-[var(--surface-container-low)] ${variants[type]}`}>
  <div class="text-[10px] tracking-[0.12em] mb-3 uppercase font-bold flex items-center gap-2 font-mono">
    {type === 'note' && <span class="w-2 h-2 bg-[var(--primary-container)]"></span>}
    {type === 'warning' && <span class="w-2 h-2 bg-[#FB7185]"></span>}
    {type === 'tip' && <span class="w-2 h-2 bg-[var(--secondary)]"></span>}
    {label}
  </div>
  <div class="text-[13px] text-[var(--muted)] leading-[1.8] font-mono m-0 [&>p]:!m-0">
    <slot />
  </div>
</div>
