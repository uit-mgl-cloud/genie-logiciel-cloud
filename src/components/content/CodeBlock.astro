---
// A wrapper component to style code blocks in MDX
interface Props {
  lang: string;
}
const { lang } = Astro.props;
---
<div class="bg-[var(--surface-container-low)] border border-[var(--ghost-border)] my-8 overflow-hidden relative group">
  <div class="flex items-center justify-between px-4 py-2 border-b border-[var(--ghost-border)] bg-[var(--surface)]">
    <span class="text-[10px] tracking-[0.1em] font-medium font-mono px-2 py-1 bg-[var(--surface-container-high)] text-[var(--muted)] uppercase">{lang}</span>
    <button class="text-[10px] text-[var(--muted)] font-mono cursor-pointer tracking-[0.06em] bg-transparent border-none uppercase hover:text-[var(--text)] transition-none copy-btn">copier</button>
  </div>
  <div class="code-content text-[13px] leading-[1.8] font-mono text-[var(--text)] whitespace-pre overflow-x-auto p-6">
    <slot />
  </div>
</div>

<script>
  const copyBtns = document.querySelectorAll('.copy-btn');
  copyBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const codeBlock = btn.closest('.group')?.querySelector('code') || btn.closest('.group')?.querySelector('.code-content');
      if (codeBlock) {
        navigator.clipboard.writeText(codeBlock.textContent || '');
        const originalText = btn.textContent;
        btn.textContent = 'COPIÉ!';
        setTimeout(() => {
          btn.textContent = originalText;
        }, 2000);
      }
    });
  });
</script>
