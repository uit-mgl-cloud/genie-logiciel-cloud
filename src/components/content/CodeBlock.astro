---
// A wrapper component to style code blocks in MDX
// Real implementation might intercept Astro's Code component or be used as an MDX component wrapper
interface Props {
  lang: string;
}
const { lang } = Astro.props;
---
<div class="bg-[var(--bg-2)] border border-[var(--border)] rounded-sm p-4.5 my-5 overflow-x-auto relative group">
  <div class="flex items-center justify-between mb-3 pb-2.5 border-b border-[var(--border)]">
    <span class="text-[9px] tracking-[0.1em] text-[var(--accent)] px-1.5 py-[1px] border border-[rgba(200,240,128,0.3)] rounded-sm uppercase">{lang}</span>
    <button class="text-[9px] text-[var(--hint)] cursor-pointer tracking-[0.06em] bg-transparent border-none uppercase hover:text-[var(--text)] transition-colors copy-btn">copier</button>
  </div>
  <div class="code-content text-[12px] leading-relaxed text-[var(--text)] whitespace-pre overflow-x-auto">
    <slot />
  </div>
</div>

<script>
  const copyBtns = document.querySelectorAll('.copy-btn');
  copyBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const codeBlock = btn.closest('.group')?.querySelector('code') || btn.closest('.group')?.querySelector('.code-content');
      if (codeBlock) {
        navigator.clipboard.writeText(codeBlock.textContent || '');
        const originalText = btn.textContent;
        btn.textContent = 'COPIÉ!';
        setTimeout(() => {
          btn.textContent = originalText;
        }, 2000);
      }
    });
  });
</script>
