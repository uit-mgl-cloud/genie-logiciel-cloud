---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}
const { headings } = Astro.props;
---
<span class="text-[9px] tracking-[0.12em] text-[var(--hint)] mb-4 block uppercase font-medium">SUR CETTE PAGE</span>
<div class="flex flex-col">
  {headings.map((h: any) => (
    <a href={`#${h.slug}`} class={`block text-[11px] text-[var(--hint)] py-1.5 cursor-pointer no-underline transition-colors duration-150 border-l border-transparent pl-2.5 -ml-2.5 hover:text-[var(--muted)] outline-item ${h.depth > 2 ? 'pl-5 text-[10px]' : ''}`}>
      {h.text}
    </a>
  ))}
</div>

<script>
  // Simple intersection observer to highlight currently visible heading
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      const id = entry.target.getAttribute('id');
      if (entry.intersectionRatio > 0 && id) {
        document.querySelectorAll('.outline-item').forEach((item) => {
          item.classList.remove('active');
        });
        const link = document.querySelector(`.outline-item[href="#${id}"]`);
        if (link) {
          link.classList.add('active');
        }
      }
    });
  });

  const headers = document.querySelectorAll('h2, h3, h4');
  headers.forEach((header) => {
    observer.observe(header);
  });
</script>

<style>
  .outline-item.active {
    color: var(--accent);
    border-left-color: var(--accent);
  }
</style>
