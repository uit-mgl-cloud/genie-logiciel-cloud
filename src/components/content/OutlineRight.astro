---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}
const { headings } = Astro.props;
---
<span class="text-[9px] tracking-[0.14em] text-[var(--muted)] mb-4 block">SUR CETTE PAGE</span>
<div class="flex flex-col">
  {headings.map((h: any) => (
    <a href={`#${h.slug}`} class={`block text-[11px] text-[var(--muted)] py-1.5 border-l border-transparent transition-all duration-150 no-underline outline-item hover:text-[var(--text)] hover:border-[var(--glass-border)] ${h.depth > 2 ? 'pl-[22px] text-[10px]' : 'pl-3'}`}>
      {h.text}
    </a>
  ))}
</div>

<script>
  // Simple intersection observer to highlight currently visible heading
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      const id = entry.target.getAttribute('id');
      if (entry.intersectionRatio > 0 && id) {
        document.querySelectorAll('.outline-item').forEach((item) => {
          item.classList.remove('active');
        });
        const link = document.querySelector(`.outline-item[href="#${id}"]`);
        if (link) {
          link.classList.add('active');
        }
      }
    });
  });

  const headers = document.querySelectorAll('h2, h3, h4');
  headers.forEach((header) => {
    observer.observe(header);
  });
</script>

<style>
  .outline-item.active {
    color: var(--electric);
    border-left-color: var(--electric);
  }
</style>
