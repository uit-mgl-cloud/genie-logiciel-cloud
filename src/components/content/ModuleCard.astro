---
interface Props {
  numero: number;
  titre: string;
  description: string;
  tags: string[];
  statut: 'ouvert' | 'a-venir' | 'termine' | 'en-cours';
  seances: number;
  featured?: boolean;
}
const { numero, titre, description, tags, statut, seances, featured } = Astro.props;
---
<a href={`/cours/module-${numero.toString().padStart(2, '0')}`} class={`block bg-[var(--surface-container-low)] border border-[var(--ghost-border)] p-6 cursor-pointer relative overflow-hidden no-underline group hover:bg-[var(--surface-container-high)] ${featured ? 'border-[var(--primary-container)]' : ''}`}>
  <div class={`text-[10px] tracking-[0.1em] font-medium font-mono flex items-center gap-2 mb-4 ${featured ? 'text-[var(--text)]' : 'text-[var(--text)]'}`}>
    {numero.toString().padStart(2, '0')}
    <span class="h-[1px] flex-1 bg-[var(--ghost-border)]"></span>
  </div>
  <div class="font-serif font-medium text-[20px] leading-[1.2] text-[var(--primary)] mb-3 tracking-tight" set:html={titre} />
  <div class="text-[12px] text-[var(--muted)] leading-[1.6] mb-5 font-mono">
    {description}
  </div>
  <div class="flex items-center justify-between">
    <div class="flex flex-wrap gap-2">
      {statut === 'en-cours' && <span class="text-[10px] tracking-[0.08em] font-medium font-mono px-2 py-1 border border-[var(--primary-container)] text-[var(--primary-container)]">En cours</span>}
      <span class="text-[10px] tracking-[0.08em] font-medium font-mono px-2 py-1 border border-[var(--ghost-border)] text-[var(--muted)] group-hover:text-[var(--text)]">{seances} séances</span>
      {tags.map(tag => (
        <span class="text-[10px] tracking-[0.08em] font-medium font-mono px-2 py-1 border border-[var(--ghost-border)] text-[var(--muted)] group-hover:text-[var(--text)]">{tag}</span>
      ))}
    </div>
    <span class="text-[14px] text-[var(--hint)] font-mono group-hover:text-[var(--text)]">→</span>
  </div>
</a>
