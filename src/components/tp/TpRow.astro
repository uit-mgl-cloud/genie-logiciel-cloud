---
import TpStatusBadge from './TpStatusBadge.astro';

interface Props {
  slug: string;
  numero: number;
  titre: string;
  module: number;
  statut: 'ouvert' | 'a-venir' | 'termine';
  isFirst?: boolean;
}
const { slug, numero, titre, module, statut, isFirst } = Astro.props;
---
<a href={`/tp/${slug}`} class="grid grid-cols-[56px_1fr_160px_80px_90px] px-5 py-3.5 border-b border-[var(--glass-border)] items-center cursor-pointer transition-colors duration-150 no-underline hover:bg-white/5 last:border-none">
  <span class="text-[10px] font-medium text-[var(--electric)] font-mono">TP·{numero.toString().padStart(2, '0')}</span>
  <span class="text-[12px] text-[var(--text)]">{titre}</span>
  <span class="text-[11px] text-[var(--muted)]">{module.toString().padStart(2, '0')} · Module</span>
  <span class="text-[10px] text-[var(--muted)]">4h</span>
  <div class="ml-auto">
    <TpStatusBadge statut={statut} />
  </div>
</a>
