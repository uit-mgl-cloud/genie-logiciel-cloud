---
import TpStatusBadge from './TpStatusBadge.astro';

interface Props {
  slug: string;
  numero: number;
  titre: string;
  module: number;
  statut: 'ouvert' | 'a-venir' | 'termine';
  isFirst?: boolean;
}
const { slug, numero, titre, module, statut, isFirst } = Astro.props;
---
<a href={`/tp/${slug}`} class="grid grid-cols-[56px_1fr_160px_80px_90px] px-5 py-4 border-b border-[var(--ghost-border)] items-center cursor-pointer no-underline hover:bg-[var(--surface-container-high)] last:border-none">
  <span class="text-[10px] font-medium text-[var(--primary)] font-mono">TP·{numero.toString().padStart(2, '0')}</span>
  <span class="text-[13px] text-[var(--text)] font-serif font-medium">{titre}</span>
  <span class="text-[11px] text-[var(--muted)] font-mono">{module.toString().padStart(2, '0')} · Module</span>
  <span class="text-[10px] text-[var(--muted)] font-mono">4h</span>
  <div class="ml-auto">
    <TpStatusBadge statut={statut} />
  </div>
</a>
