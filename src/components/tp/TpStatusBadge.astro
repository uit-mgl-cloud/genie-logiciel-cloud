---
interface Props {
  statut: 'ouvert' | 'a-venir' | 'termine';
}
const { statut } = Astro.props;
---
{statut === 'ouvert' && <span class="inline-flex items-center gap-1.5 text-[10px] tracking-[0.08em] font-medium font-mono px-2 py-1 border border-[var(--primary)] text-[var(--primary)] uppercase bg-[var(--surface)]">Ouvert</span>}
{statut === 'a-venir' && <span class="inline-flex items-center gap-1.5 text-[10px] tracking-[0.08em] font-medium font-mono px-2 py-1 border border-[var(--ghost-border)] text-[var(--muted)] uppercase bg-[var(--surface)]">À venir</span>}
{statut === 'termine' && <span class="inline-flex items-center gap-1.5 text-[10px] tracking-[0.08em] font-medium font-mono px-2 py-1 border border-[var(--ghost-border)] text-[var(--hint)] uppercase bg-[var(--surface)]">Terminé</span>}
