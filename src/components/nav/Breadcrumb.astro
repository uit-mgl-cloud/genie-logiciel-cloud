---
interface Props {
  context: 'cours' | 'tp' | 'projet' | 'contribution';
  module?: number;
  seance?: number;
  title: string;
}

const { context, module, seance, title } = Astro.props;
---

<div class="flex items-center gap-1.5 text-[11px] text-[var(--muted)]">
  <span class="capitalize">{context}</span>
  <span class="text-[var(--hint)]">/</span>
  {module !== undefined && (
    <>
      <span>Module {module.toString().padStart(2, '0')}</span>
      <span class="text-[var(--hint)]">/</span>
    </>
  )}
  <span class="text-[var(--text)] truncate max-w-[120px] md:max-w-[300px]" set:html={title} />
</div>
