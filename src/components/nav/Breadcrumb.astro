---
interface Props {
  context: 'cours' | 'tp' | 'projet' | 'contribution';
  module?: number;
  seance?: number;
  title: string;
}

const { context, module, seance, title } = Astro.props;
---

<div class="flex items-center gap-2 text-[11px] text-[var(--muted)] font-mono">
  <span class="uppercase font-medium text-[var(--text)]">{context}</span>
  <span class="text-[var(--ghost-border)]">/</span>
  {module !== undefined && (
    <>
      <span class="uppercase">Mod {module.toString().padStart(2, '0')}</span>
      <span class="text-[var(--ghost-border)]">/</span>
    </>
  )}
  <span class="text-[var(--muted)] truncate max-w-[120px] md:max-w-[300px]" set:html={title} />
</div>
