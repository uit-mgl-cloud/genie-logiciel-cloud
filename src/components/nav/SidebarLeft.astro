---
interface Props {
  activeModule?: number;
  activeSeance?: number;
}

const { activeModule, activeSeance } = Astro.props;

import { getCollection } from 'astro:content';
const coursItems = await getCollection('cours');

// Group cours items by module
const modulesMap = coursItems.reduce((acc, curr) => {
  const mod = curr.data.module;
  if (!acc[mod]) acc[mod] = [];
  acc[mod].push(curr);
  return acc;
}, {} as Record<number, any[]>);

// Sort modules and their seances
const sortedModules = Object.keys(modulesMap).map(Number).sort((a, b) => a - b);
sortedModules.forEach(mod => {
  modulesMap[mod].sort((a, b) => a.data.seance - b.data.seance);
});
---

<div class="flex flex-col gap-8">
  {sortedModules.map((mod) => {
    const isModuleActive = activeModule === mod;
    
    return (
      <div class="mb-0">
        <div class="flex items-center gap-2 px-5 py-2 mb-2 bg-[var(--surface-container-low)]">
          <span class="text-[10px] text-[var(--text)] tracking-[0.1em] font-medium uppercase">
            MODULE {mod.toString().padStart(2, '0')}
          </span>
        </div>
        
        <div class="flex flex-col">
          {modulesMap[mod].map((seance) => {
            const isActive = activeModule === mod && activeSeance === seance.data.seance;
            return (
              <a 
                href={`/cours/module-${mod.toString().padStart(2, '0')}/seance-${seance.data.seance}`}
                class={`flex items-center px-5 py-2 cursor-pointer no-underline relative group hover:bg-[var(--surface-container-low)] ${isActive ? 'bg-[var(--surface-container-high)] border-l-[3px] border-[var(--primary)] pl-[17px]' : 'border-l pl-[20px] border-[var(--ghost-border)]'}`}
              >
                <div>
                  <div class={`text-[12px] leading-[1.5] ${isActive ? 'text-[var(--text)] font-medium' : 'text-[var(--muted)] group-hover:text-[var(--text)]'}`}>
                    {seance.data.titre}
                  </div>
                  <div class="text-[10px] text-[var(--hint)] tracking-[0.06em] mt-1 uppercase">
                    Séance {seance.data.seance}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    );
  })}
</div>
