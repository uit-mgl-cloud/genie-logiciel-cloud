---
const activePath = Astro.url.pathname;
const isActive = (path: string) => activePath.startsWith(path) || (path === '/' && activePath === '/') ? 'active' : '';
---

<nav class="flex items-center justify-between px-6 md:px-12 lg:px-20 xl:px-32 py-0 h-[60px] border-b border-[var(--glass-border)] sticky top-0 bg-[rgba(8,11,18,0.7)] backdrop-blur-xl z-50">
  <div class="flex items-center gap-2.5">
    <a href="/" class="font-syne font-extrabold text-[15px] md:text-[17px] bg-clip-text text-transparent bg-gradient-to-r from-[var(--electric)] to-[var(--violet)] tracking-tighter no-underline">GL·Cloud</a>
    <span class="text-[9px] font-mono font-medium tracking-[0.12em] px-2 py-0.5 rounded-full bg-[rgba(110,231,247,0.1)] border border-[rgba(110,231,247,0.25)] text-[var(--electric)] hidden sm:inline-block">M2 · 2025</span>
  </div>
  <div class="hidden md:flex gap-1 md:gap-2">
    <a href="/cours" class={`px-3.5 py-1.5 rounded-lg text-[12px] text-[var(--muted)] no-underline transition-all duration-150 font-mono hover:text-[var(--text)] hover:bg-[var(--glass)] ${isActive('/cours')}`}>Cours</a>
    <a href="/tp" class={`px-3.5 py-1.5 rounded-lg text-[12px] text-[var(--muted)] no-underline transition-all duration-150 font-mono hover:text-[var(--text)] hover:bg-[var(--glass)] ${isActive('/tp')}`}>TP</a>
    <a href="/projets" class={`px-3.5 py-1.5 rounded-lg text-[12px] text-[var(--muted)] no-underline transition-all duration-150 font-mono hover:text-[var(--text)] hover:bg-[var(--glass)] ${isActive('/projets')}`}>Projets</a>
    <a href="/contributions" class={`px-3.5 py-1.5 rounded-lg text-[12px] text-[var(--muted)] no-underline transition-all duration-150 font-mono hover:text-[var(--text)] hover:bg-[var(--glass)] ${isActive('/contributions')}`}>Contributions</a>
  </div>
  <div class="flex items-center gap-3.5">
    <a href="/contribuer" class="flex items-center gap-2 px-3 sm:px-4 py-2 rounded-lg text-[11px] sm:text-[12px] font-mono bg-[var(--glass)] border border-[var(--glass-border)] text-[var(--text)] cursor-pointer transition-all duration-150 hover:border-[rgba(110,231,247,0.4)] hover:bg-[rgba(110,231,247,0.06)] no-underline">
      <span class="w-1.5 h-1.5 rounded-full bg-[var(--lime)] shadow-[0_0_8px_var(--lime)]"></span>
      <span class="hidden sm:inline">Contribuer via GitHub</span>
      <span class="sm:hidden">Contribuer</span>
    </a>
  </div>
</nav>

<style>
  .active {
    color: var(--electric) !important;
    background: var(--glass);
  }
</style>
