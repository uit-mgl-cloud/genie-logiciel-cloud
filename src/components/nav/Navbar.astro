---
const activePath = Astro.url.pathname;
const isActive = (path: string) => activePath.startsWith(path) || (path === '/' && activePath === '/') ? 'bg-[var(--surface-container-high)] text-[var(--text)]' : 'text-[var(--muted)]';
---

<nav class="flex items-center justify-between px-6 md:px-12 lg:px-20 xl:px-32 py-0 h-[60px] border-b border-[var(--ghost-border)] sticky top-0 bg-[var(--surface)] z-50">
  <div class="flex items-center gap-4">
    <a href="/" class="font-serif font-semibold text-[18px] md:text-[20px] text-[var(--text)] tracking-tight no-underline">GL·Cloud</a>
    <span class="text-[10px] font-mono tracking-[0.1em] px-2 py-0.5 bg-[var(--surface-container-high)] text-[var(--muted)] hidden sm:inline-block">v3.0.0</span>
  </div>
  <div class="hidden md:flex gap-1 md:gap-2">
    <a href="/cours" class={`px-4 py-2 text-[12px] no-underline font-mono hover:text-[var(--text)] hover:bg-[var(--surface-container-high)] ${isActive('/cours')}`}>Cours</a>
    <a href="/tp" class={`px-4 py-2 text-[12px] no-underline font-mono hover:text-[var(--text)] hover:bg-[var(--surface-container-high)] ${isActive('/tp')}`}>TP</a>
    <a href="/projets" class={`px-4 py-2 text-[12px] no-underline font-mono hover:text-[var(--text)] hover:bg-[var(--surface-container-high)] ${isActive('/projets')}`}>Projets</a>
    <a href="/contributions" class={`px-4 py-2 text-[12px] no-underline font-mono hover:text-[var(--text)] hover:bg-[var(--surface-container-high)] ${isActive('/contributions')}`}>Contributions</a>
  </div>
  <div class="flex items-center gap-3.5">
    <a href="/contribuer" class="flex items-center justify-center px-4 py-2 text-[11px] sm:text-[12px] font-mono bg-[var(--primary-container)] text-[var(--on-primary-container)] font-medium hover:opacity-80 no-underline cursor-pointer min-w-[120px]">
      <span class="hidden sm:inline">Contribuer via GitHub</span>
      <span class="sm:hidden">Contribuer</span>
    </a>
  </div>
</nav>
