---
interface Props {
  username: string;
}
const { username } = Astro.props;
// Simple initial generator (first 2 chars of the username)
const initials = username.substring(0, 2).toUpperCase();
---
<div class="flex items-center gap-2">
  <div class="w-[22px] h-[22px] rounded-full bg-[var(--bg-3)] border border-[var(--border-2)] flex items-center justify-center text-[9px] text-[var(--muted)] shrink-0">
    {initials}
  </div>
  <span class="text-[11px] text-[var(--muted)]">{username}</span>
</div>
