---
import AuthorTag from './AuthorTag.astro';

interface Props {
  slug: string;
  type: string;
  titre: string;
  auteur: string;
  module?: number;
  date: Date;
}
const { slug, type, titre, auteur, module, date } = Astro.props;

// Basic date formatter for the UI to represent "il y a 3 jours"
// If the relative time API fails, we fall back to a simple string
let timeAgo = '';
try {
  const rtf = new Intl.RelativeTimeFormat('fr', { numeric: 'auto' });
  const daysDifference = Math.round((date.getTime() - new Date().getTime()) / (1000 * 60 * 60 * 24));
  timeAgo = rtf.format(daysDifference, 'day');
} catch (e) {
  timeAgo = date.toLocaleDateString();
}
// avatar initials
const initials = auteur.substring(0, 2).toUpperCase();
---
<a href={`/contributions/${type}/${slug}`} class="block bg-[var(--glass)] border border-[var(--glass-border)] rounded-2xl p-5.5 cursor-pointer transition-all duration-200 relative overflow-hidden group hover:border-[rgba(167,139,250,0.25)] hover:bg-[rgba(167,139,250,0.04)] hover:-translate-y-0.5 no-underline">
  <div class="flex items-center gap-2.5 mb-3.5">
    <div class="w-8 h-8 rounded-[10px] bg-gradient-to-br from-[var(--electric)] to-[var(--violet)] flex items-center justify-center text-[11px] font-bold text-[#080B12] font-syne shrink-0">{initials}</div>
    <div class="flex-1">
      <div class="text-[12px] text-[var(--text)] mb-0.5">{auteur}</div>
      <div class="text-[10px] text-[var(--muted)]">{timeAgo}</div>
    </div>
    <span class={`text-[9px] tracking-[0.08em] px-2.5 py-[3px] rounded-md uppercase ${
      type === 'etude-de-cas' ? 'bg-[rgba(251,113,133,0.1)] border border-[rgba(251,113,133,0.25)] text-[var(--rose)]' : 
      type === 'solution-tp' ? 'bg-[rgba(163,230,53,0.1)] border border-[rgba(163,230,53,0.25)] text-[var(--lime)]' : 
      type === 'ressource' ? 'bg-[rgba(110,231,247,0.1)] border border-[rgba(110,231,247,0.25)] text-[var(--electric)]' : 
      'bg-[rgba(167,139,250,0.1)] border border-[rgba(167,139,250,0.25)] text-[var(--violet)]'
    }`}>
      {type.replace(/-/g, ' ')}
    </span>
  </div>
  <div class="font-syne text-[14px] font-bold text-[var(--text)] leading-[1.35] mb-2" set:html={titre} />
  <div class="flex flex-wrap gap-1.5">
    {module && <span class="text-[9px] tracking-[0.08em] font-medium px-2.5 py-0.5 rounded-full border border-[var(--glass-border)] text-[var(--muted)]">TP/MODULE {module}</span>}
  </div>
</a>
