---
import AuthorTag from './AuthorTag.astro';

interface Props {
  slug: string;
  type: string;
  titre: string;
  auteur: string;
  module?: number;
  date: Date;
}
const { slug, type, titre, auteur, module, date } = Astro.props;

// Basic date formatter for the UI to represent "il y a 3 jours"
// If the relative time API fails, we fall back to a simple string
let timeAgo = '';
try {
  const rtf = new Intl.RelativeTimeFormat('fr', { numeric: 'auto' });
  const daysDifference = Math.round((date.getTime() - new Date().getTime()) / (1000 * 60 * 60 * 24));
  timeAgo = rtf.format(daysDifference, 'day');
} catch (e) {
  timeAgo = date.toLocaleDateString();
}
// avatar initials
const initials = auteur.substring(0, 2).toUpperCase();
---
<a href={`/contributions/${type}/${slug}`} class="block bg-[var(--surface-container-low)] border border-[var(--ghost-border)] p-6 cursor-pointer relative group hover:bg-[var(--surface-container-high)] no-underline">
  <div class="flex items-center gap-3 mb-4">
    <div class="w-10 h-10 bg-[var(--surface-container-high)] border border-[var(--ghost-border)] flex items-center justify-center text-[12px] font-medium text-[var(--text)] font-mono shrink-0">{initials}</div>
    <div class="flex-1">
      <div class="text-[12px] text-[var(--text)] mb-1 font-mono font-medium">{auteur}</div>
      <div class="text-[10px] text-[var(--muted)] font-mono">{timeAgo}</div>
    </div>
    <span class={`text-[10px] tracking-[0.08em] px-2.5 py-1 uppercase font-mono border border-[var(--ghost-border)] ${
      type === 'etude-de-cas' ? 'text-[var(--secondary)]' : 
      type === 'solution-tp' ? 'text-[var(--primary)]' : 
      type === 'ressource' ? 'text-[var(--text)]' : 
      'text-[var(--muted)]'
    }`}>
      {type.replace(/-/g, ' ')}
    </span>
  </div>
  <div class="font-serif text-[18px] font-medium text-[var(--text)] leading-[1.3] mb-3" set:html={titre} />
  <div class="flex flex-wrap gap-2">
    {module && <span class="text-[10px] tracking-[0.08em] font-medium px-2 py-1 border border-[var(--ghost-border)] text-[var(--muted)] font-mono">TP/MODULE {module}</span>}
  </div>
</a>
