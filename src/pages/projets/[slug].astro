---
import Base from "../../layouts/Base.astro";
import Breadcrumb from "../../components/nav/Breadcrumb.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projets = await getCollection("projets");
  return projets.map((entry) => ({
    params: {
      slug: entry.id
        .split("/")
        .pop()
        ?.replace(/\.mdx?$/, ""),
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Base title={entry.data.titre} description={entry.data.description}>
  <div
    class="flex items-center gap-2 text-[11px] text-[var(--hint)] px-10 py-4 border-b border-[var(--border)]"
  >
    <Breadcrumb context="projet" title={entry.data.titre} />
  </div>

  <main class="max-w-[720px] mx-auto px-12 py-16">
    <div
      class="text-[10px] tracking-[0.1em] text-[var(--accent)] mb-4 flex items-center gap-2 before:content-[''] before:inline-block before:w-4 before:h-[1px] before:bg-[var(--accent)]"
    >
      PROJET
    </div>

    <h1
      class="font-serif text-[42px] font-light leading-tight tracking-tight mb-4 text-[var(--text)]"
      set:html={entry.data.titre}
    />

    <div
      class="flex gap-6 mb-8 pb-8 border-b border-[var(--border)] text-[11px] flex-wrap"
    >
      <div class="flex flex-col gap-1">
        <span class="text-[var(--hint)] text-[9px] uppercase tracking-wider"
          >Modules couverts</span
        >
        <span class="text-[var(--muted)]">{entry.data.modules.join(", ")}</span>
      </div>
      <div class="flex flex-col gap-1">
        <span class="text-[var(--hint)] text-[9px] uppercase tracking-wider"
          >Livrable attendu</span
        >
        <span class="text-[var(--muted)]">{entry.data.livrable}</span>
      </div>
      <div class="flex flex-col gap-1">
        <span class="text-[var(--hint)] text-[9px] uppercase tracking-wider"
          >Taille de l'équipe</span
        >
        <span class="text-[var(--muted)]"
          >{entry.data.equipe} personnes max</span
        >
      </div>
      {
        entry.data.deadline && (
          <div class="flex flex-col gap-1">
            <span class="text-[var(--hint)] text-[9px] uppercase tracking-wider">
              Deadline
            </span>
            <span class="text-[var(--muted)]">
              {entry.data.deadline.toLocaleDateString("fr-FR")}
            </span>
          </div>
        )
      }
    </div>

    <div class="text-[14px] text-[var(--muted)] leading-relaxed mb-10">
      {entry.data.description}
    </div>

    <div class="prose mb-16">
      <Content />
    </div>
  </main>
</Base>
