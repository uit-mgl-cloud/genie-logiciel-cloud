---
import Base from '../layouts/Base.astro';
import ModuleCard from '../components/content/ModuleCard.astro';
import TpRow from '../components/tp/TpRow.astro';
import ContribCard from '../components/contributions/ContribCard.astro';
import { getCollection } from 'astro:content';

const cours = await getCollection('cours');
const modulesMap = cours.reduce((acc, curr) => {
  const mod = curr.data.module;
  if (!acc[mod]) acc[mod] = [];
  acc[mod].push(curr);
  return acc;
}, {} as Record<number, any[]>);
const sortedModules = Object.keys(modulesMap).map(Number).sort((a, b) => a - b).slice(0, 6);

const tps = await getCollection('tp');
tps.sort((a, b) => a.data.numero - b.data.numero);
const featuredTps = tps.slice(0, 4);

const contributions = await getCollection('contributions');
contributions.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredContribs = contributions.slice(0, 4);
---
<Base hideNavbar={false} title="Génie Logiciel pour le Cloud" description="Plateforme collaborative du cours M2. Cours, TP, projets et contributions étudiantes — tout est open source, tout est versionné.">
  <div class="px-8 max-w-[1264px] mx-auto w-full">
    <div class="py-[72px] pb-[64px] grid grid-cols-1 md:grid-cols-[1fr_340px] gap-12 items-start">
      <div class="animate-[fadeUp_0.6s_ease_both]">
        <div class="inline-flex items-center gap-2 text-[10px] tracking-[0.14em] text-[var(--muted)] mb-7 px-3 py-1.5 rounded-md border border-[var(--glass-border)] bg-[var(--glass)]">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--lime)] animate-[pulseBorder_2s_ease-in-out_infinite]"></span>
          MASTER INFORMATIQUE · SEMESTRE 2 · OPEN SOURCE
        </div>
        <h1 class="font-syne font-extrabold text-[52px] md:text-[62px] leading-[0.95] tracking-[-0.04em] mb-7">
          <div class="text-[var(--text)]">Génie</div>
          <div class="bg-gradient-to-r from-[var(--electric)] via-[var(--violet)] to-[var(--rose)] bg-[length:200%] bg-clip-text text-transparent animate-[gradShift_4s_linear_infinite]">Logiciel</div>
          <div class="text-[rgba(241,245,249,0.35)]">Cloud Computing</div>
        </h1>
        <p class="text-[13px] text-[var(--muted)] leading-[1.8] max-w-[480px] mb-9">Plateforme collaborative du cours M2. Cours, TP et projets cloud — entièrement open source, versionné sur GitHub, enrichi par chaque promotion.</p>
        <div class="flex gap-3 flex-wrap">
          <a href="/cours" class="inline-block px-6 py-2.5 rounded-xl text-[13px] font-mono font-medium bg-gradient-to-br from-[var(--electric)] to-[var(--violet)] text-[#080B12] border-none cursor-pointer transition-all duration-150 shadow-[0_0_32px_rgba(110,231,247,0.2)] hover:opacity-90 hover:-translate-y-[1px] no-underline">Commencer le cours →</a>
          <a href="https://github.com" target="_blank" class="inline-block px-6 py-2.5 rounded-xl text-[13px] font-mono bg-[var(--glass)] border border-[var(--glass-border)] text-[var(--text)] cursor-pointer transition-all duration-150 hover:border-white/20 hover:bg-white/5 no-underline">Voir sur GitHub</a>
        </div>
      </div>
      <div class="animate-[fadeUp_0.6s_0.15s_ease_both]">
        <div class="bg-[var(--glass)] border border-[var(--glass-border)] rounded-[20px] p-7 backdrop-blur-md relative overflow-hidden before:content-[''] before:absolute before:inset-0 before:bg-gradient-to-br before:from-[rgba(110,231,247,0.06)] before:to-[rgba(167,139,250,0.04)] before:pointer-events-none">
          <div class="text-[9px] tracking-[0.14em] text-[var(--muted)] mb-5">PLATEFORME · STATS EN DIRECT</div>
          <div class="flex items-center justify-between py-3.5 border-b border-[var(--glass-border)]">
            <span class="text-[12px] text-[var(--muted)]">Modules de cours</span>
            <span class="font-syne font-bold text-[22px] bg-gradient-to-r from-[var(--electric)] to-[var(--violet)] bg-clip-text text-transparent">{Object.keys(modulesMap).length.toString().padStart(2, '0')}</span>
          </div>
          <div class="flex items-center justify-between py-3.5 border-b border-[var(--glass-border)]">
            <span class="text-[12px] text-[var(--muted)]">Travaux pratiques</span>
            <span class="font-syne font-bold text-[22px] bg-gradient-to-r from-[var(--electric)] to-[var(--violet)] bg-clip-text text-transparent">{tps.length.toString().padStart(2, '0')}</span>
          </div>
          <div class="flex items-center justify-between py-3.5 border-b border-[var(--glass-border)]">
            <span class="text-[12px] text-[var(--muted)]">Contributions étudiantes</span>
            <span class="font-syne font-bold text-[22px] bg-gradient-to-r from-[var(--lime)] to-[var(--electric)] bg-clip-text text-transparent">{contributions.length.toString().padStart(2, '0')}</span>
          </div>
          <div class="flex items-center justify-between py-3.5 border-b border-[var(--glass-border)]">
            <span class="text-[12px] text-[var(--muted)]">Étudiants actifs</span>
            <span class="font-syne font-bold text-[22px] bg-gradient-to-r from-[var(--rose)] to-[var(--violet)] bg-clip-text text-transparent">18</span>
          </div>          
        </div>
      </div>
    </div>
  </div>

  <div class="px-8 max-w-[1264px] mx-auto w-full">
    <div class="flex items-center justify-between mb-6 pb-4 border-b border-[var(--glass-border)]">
      <span class="font-syne font-bold text-[13px] tracking-[0.08em] text-[var(--muted)] uppercase flex items-center gap-2.5 before:content-[''] before:w-[18px] before:h-0.5 before:rounded-full before:bg-gradient-to-r before:from-[var(--electric)] before:to-[var(--violet)]">Modules du cours</span>
      <a href="/cours" class="text-[11px] text-[var(--muted)] no-underline transition-colors duration-150 hover:text-[var(--electric)]">Voir tous →</a>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-16">
      {sortedModules.map((mod, i) => (
        <ModuleCard 
          numero={mod}
          titre={`Module ${mod}`}
          description="Informations à propos du module... Concepts fondamentaux et avancés."
          tags={[]}
          statut={i === 0 ? 'en-cours' : 'a-venir'}
          seances={modulesMap[mod].length}
          featured={i === 0}
        />
      ))}
      {sortedModules.length === 0 && (
        <div class="p-8 text-[12px] text-[var(--muted)] col-span-3 border border-[var(--glass-border)] bg-[var(--glass)] rounded-2xl rounded-2xl">Aucun module pour le moment.</div>
      )}
    </div>
  </div>

  <div class="h-px bg-gradient-to-r from-transparent via-[var(--glass-border)] to-transparent my-12 mx-8 max-w-[1200px] xl:mx-auto"></div>

  <div class="px-8 max-w-[1264px] mx-auto w-full mb-16">
    <div class="flex items-center justify-between mb-6 pb-4 border-b border-[var(--glass-border)]">
      <span class="font-syne font-bold text-[13px] tracking-[0.08em] text-[var(--muted)] uppercase flex items-center gap-2.5 before:content-[''] before:w-[18px] before:h-0.5 before:rounded-full before:bg-gradient-to-r before:from-[var(--electric)] before:to-[var(--violet)]">Travaux pratiques</span>
      <a href="/tp" class="text-[11px] text-[var(--muted)] no-underline transition-colors duration-150 hover:text-[var(--electric)]">{tps.length} TP au total →</a>
    </div>

    <div class="bg-[var(--glass)] border border-[var(--glass-border)] rounded-2xl overflow-hidden shadow-sm">
      <div class="grid grid-cols-[56px_1fr_160px_80px_90px] px-5 py-3 border-b border-[var(--glass-border)] text-[9px] tracking-[0.12em] text-[var(--muted)] uppercase">
        <span>N°</span>
        <span>Intitulé</span>
        <span>Module</span>
        <span>Durée</span>
        <span class="text-right pr-2">Statut</span>
      </div>
      <div class="flex flex-col">
        {featuredTps.map((tp, i) => (
          <TpRow 
            slug={tp.id.split('/').pop()?.replace(/\.mdx?$/, '') || ''} 
            numero={tp.data.numero} 
            titre={tp.data.titre} 
            module={tp.data.module} 
            statut={tp.data.statut} 
          />
        ))}
        {featuredTps.length === 0 && (
          <div class="px-6 md:px-12 lg:px-20 xl:px-32 py-8 text-[12px] text-[var(--muted)]">Aucun TP pour le moment.</div>
        )}
      </div>
    </div>
  </div>

  <div class="px-8 max-w-[1264px] mx-auto w-full mb-16">
    <div class="flex items-center justify-between mb-6 pb-4 border-b border-[var(--glass-border)]">
      <span class="font-syne font-bold text-[13px] tracking-[0.08em] text-[var(--muted)] uppercase flex items-center gap-2.5 before:content-[''] before:w-[18px] before:h-0.5 before:rounded-full before:bg-gradient-to-r before:from-[var(--electric)] before:to-[var(--violet)]">Contributions étudiantes</span>
      <a href="/contributions" class="text-[11px] text-[var(--muted)] no-underline transition-colors duration-150 hover:text-[var(--electric)]">Voir toutes →</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {featuredContribs.map((c) => (
        <ContribCard 
          slug={c.id.split('/').pop()?.replace(/\.mdx?$/, '') || ''}
          type={c.data.type}
          titre={c.data.titre}
          auteur={c.data.auteur}
          module={c.data.module}
          date={c.data.date}
        />
      ))}
      {featuredContribs.length === 0 && (
        <div class="p-8 text-[12px] text-[var(--muted)] col-span-2 border border-[var(--glass-border)] bg-[var(--glass)] rounded-2xl">Aucune contribution pour le moment.</div>
      )}
    </div>
  </div>
</Base>
