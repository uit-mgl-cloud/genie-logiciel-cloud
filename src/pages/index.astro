---
import Base from '../layouts/Base.astro';
import ModuleCard from '../components/content/ModuleCard.astro';
import TpRow from '../components/tp/TpRow.astro';
import ContribCard from '../components/contributions/ContribCard.astro';
import { getCollection } from 'astro:content';

const cours = await getCollection('cours');
const modulesMap = cours.reduce((acc, curr) => {
  const mod = curr.data.module;
  if (!acc[mod]) acc[mod] = [];
  acc[mod].push(curr);
  return acc;
}, {} as Record<number, any[]>);
const sortedModules = Object.keys(modulesMap).map(Number).sort((a, b) => a - b).slice(0, 6);

const tps = await getCollection('tp');
tps.sort((a, b) => a.data.numero - b.data.numero);
const featuredTps = tps.slice(0, 4);

const contributions = await getCollection('contributions');
contributions.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredContribs = contributions.slice(0, 4);
---
<Base hideNavbar={false} title="Génie Logiciel pour le Cloud" description="Plateforme collaborative du cours M2. Cours, TP, projets et contributions étudiantes — tout est open source, tout est versionné.">
  <div class="px-8 max-w-[1264px] mx-auto w-full">
    <div class="py-20 grid grid-cols-1 md:grid-cols-[1fr_360px] gap-16 items-start">
      <div>
        <div class="inline-flex items-center gap-2 text-[10px] uppercase tracking-[0.14em] text-[var(--muted)] mb-8 font-mono">
          <span class="w-1.5 h-1.5 bg-[var(--primary)]"></span>
          Master Informatique · Semestre 2
        </div>
        <h1 class="font-serif font-light text-[62px] md:text-[84px] leading-[0.9] tracking-[-0.03em] mb-8 text-[var(--text)]">
          Génie Logiciel<br/>
          <span class="italic text-[var(--primary)] font-light">Cloud Computing</span>
        </h1>
        <p class="text-[14px] text-[var(--muted)] leading-[1.8] max-w-[480px] mb-10 font-mono">Plateforme collaborative du cours M2. Cours, TP et projets cloud — entièrement open source, versionné sur GitHub, enrichi par chaque promotion.</p>
        <div class="flex gap-4 flex-wrap mt-6">
          <a href="/cours" class="inline-flex items-center justify-center px-8 py-3 text-[13px] font-mono bg-[var(--primary-container)] text-[var(--on-primary-container)] font-medium hover:opacity-80 no-underline cursor-pointer">Commencer le cours</a>
          <a href="https://github.com" target="_blank" class="inline-flex items-center justify-center px-8 py-3 text-[13px] font-mono bg-[var(--surface)] text-[var(--text)] border border-[var(--ghost-border)] hover:bg-[var(--surface-container-low)] no-underline cursor-pointer">Voir sur GitHub</a>
        </div>
      </div>
      <div class="bg-[var(--surface-container-low)] p-10 border border-[var(--ghost-border)] mt-6 md:mt-0">
        <div class="text-[10px] tracking-[0.14em] text-[var(--muted)] mb-8 uppercase font-mono font-medium">Stats en direct</div>
        
        <div class="flex items-end justify-between py-4 border-b border-[var(--ghost-border)]">
          <span class="text-[12px] text-[var(--muted)] font-mono">Modules de cours</span>
          <span class="font-serif font-medium text-[32px] leading-none text-[var(--text)]">{Object.keys(modulesMap).length.toString().padStart(2, '0')}</span>
        </div>
        <div class="flex items-end justify-between py-4 border-b border-[var(--ghost-border)]">
          <span class="text-[12px] text-[var(--muted)] font-mono">Travaux pratiques</span>
          <span class="font-serif font-medium text-[32px] leading-none text-[var(--text)]">{tps.length.toString().padStart(2, '0')}</span>
        </div>
        <div class="flex items-end justify-between py-4 border-b border-[var(--ghost-border)]">
          <span class="text-[12px] text-[var(--muted)] font-mono">Contributions étudiantes</span>
          <span class="font-serif font-medium text-[32px] leading-none text-[var(--text)]">{contributions.length.toString().padStart(2, '0')}</span>
        </div>
        <div class="flex items-end justify-between py-4 border-b border-[var(--ghost-border)]">
          <span class="text-[12px] text-[var(--muted)] font-mono">Étudiants actifs</span>
          <span class="font-serif font-medium text-[32px] leading-none text-[var(--text)]">18</span>
        </div>
        <div class="flex items-end justify-between py-4">
          <span class="text-[12px] text-[var(--muted)] font-mono">Coût d'hébergement</span>
          <span class="font-serif font-medium text-[32px] leading-none text-[var(--secondary)]">0€</span>
        </div>
      </div>
    </div>
  </div>

  <div class="px-8 max-w-[1264px] mx-auto w-full mt-12 mb-20">
    <div class="flex items-center justify-between mb-8 pb-6 border-b border-[var(--ghost-border)]">
      <span class="font-mono text-[12px] tracking-[0.1em] text-[var(--muted)] uppercase font-medium">Modules du cours</span>
      <a href="/cours" class="text-[12px] font-mono text-[var(--text)] no-underline hover:text-[var(--secondary)]">Voir tous →</a>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {sortedModules.map((mod, i) => (
        <ModuleCard 
          numero={mod}
          titre={`Module ${mod}`}
          description="Informations à propos du module... Concepts fondamentaux et avancés."
          tags={[]}
          statut={i === 0 ? 'en-cours' : 'a-venir'}
          seances={modulesMap[mod].length}
          featured={i === 0}
        />
      ))}
      {sortedModules.length === 0 && (
        <div class="p-10 font-mono text-[13px] text-[var(--muted)] col-span-3 border border-[var(--ghost-border)] bg-[var(--surface-container-low)] text-center">Aucun module pour le moment.</div>
      )}
    </div>
  </div>

  <div class="px-8 max-w-[1264px] mx-auto w-full mb-20">
    <div class="flex items-center justify-between mb-8 pb-6 border-b border-[var(--ghost-border)]">
      <span class="font-mono text-[12px] tracking-[0.1em] text-[var(--muted)] uppercase font-medium">Travaux pratiques</span>
      <a href="/tp" class="text-[12px] font-mono text-[var(--text)] no-underline hover:text-[var(--secondary)]">{tps.length} TP au total →</a>
    </div>

    <div class="bg-[var(--surface-container-low)] border border-[var(--ghost-border)]">
      <div class="grid grid-cols-[56px_1fr_160px_80px_90px] px-5 py-4 border-b border-[var(--ghost-border)] text-[10px] font-mono tracking-[0.1em] text-[var(--muted)] uppercase font-medium">
        <span>N°</span>
        <span>Intitulé</span>
        <span>Module</span>
        <span>Durée</span>
        <span class="text-right pr-2">Statut</span>
      </div>
      <div class="flex flex-col">
        {featuredTps.map((tp, i) => (
          <TpRow 
            slug={tp.id.split('/').pop()?.replace(/\.mdx?$/, '') || ''} 
            numero={tp.data.numero} 
            titre={tp.data.titre} 
            module={tp.data.module} 
            statut={tp.data.statut} 
          />
        ))}
        {featuredTps.length === 0 && (
          <div class="px-8 py-10 font-mono text-[13px] text-[var(--muted)] text-center">Aucun TP pour le moment.</div>
        )}
      </div>
    </div>
  </div>

  <div class="px-8 max-w-[1264px] mx-auto w-full mb-24">
    <div class="flex items-center justify-between mb-8 pb-6 border-b border-[var(--ghost-border)]">
      <span class="font-mono text-[12px] tracking-[0.1em] text-[var(--muted)] uppercase font-medium">Contributions étudiantes</span>
      <a href="/contributions" class="text-[12px] font-mono text-[var(--text)] no-underline hover:text-[var(--secondary)]">Voir toutes →</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {featuredContribs.map((c) => (
        <ContribCard 
          slug={c.id.split('/').pop()?.replace(/\.mdx?$/, '') || ''}
          type={c.data.type}
          titre={c.data.titre}
          auteur={c.data.auteur}
          module={c.data.module}
          date={c.data.date}
        />
      ))}
      {featuredContribs.length === 0 && (
        <div class="p-10 font-mono text-[13px] text-[var(--muted)] col-span-2 border border-[var(--ghost-border)] bg-[var(--surface-container-low)] text-center">Aucune contribution pour le moment.</div>
      )}
    </div>
  </div>
</Base>
